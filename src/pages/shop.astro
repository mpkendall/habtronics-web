---
import Layout from "../layouts/Layout.astro";
import ProductCard from "../components/ProductCard.astro";
import { getProductData, resolveStripeKey } from "../lib/stripe";

export const prerender = false;

let products = [];
const runtimeEnv = (Astro.locals as any)?.runtime?.env;

try {
	const stripeKey = resolveStripeKey(runtimeEnv);
	products = await getProductData(stripeKey);
} catch (error) {
	console.error("Error fetching product metadata:", error);
}
---

<Layout>
	<h1 class="sr-only">Shop</h1>
	<section class="bg-white py-10 md:py-16">
		<div class="max-w-[1150px] mx-auto px-4">
			<!-- Banner -->
			<div class="flex flex-col md:flex-row items-center justify-center gap-4 md:gap-0 mb-8 md:mb-12">
				<img
					src="/logos/habtronics.svg"
					alt="Habtronics logo"
					class="h-20 md:h-28 mb-0 md:mr-6"
				/>
				<form role="search" id="search-form" onsubmit="return false;" class="w-full md:w-auto">
					<label for="search-input" class="sr-only">Search products</label>
					<input
						type="text"
						id="search-input"
						placeholder="Search"
						aria-label="Search products"
						class="w-full md:w-80 h-12 px-4 border-2 border-black rounded-md font-inter text-base md:text-lg placeholder:text-base md:placeholder:text-lg placeholder:font-inter focus:outline-none focus:ring-2 focus:ring-black"
					/>
				</form>
			</div>

			<!-- Category Title -->
			<h2 class="text-3xl md:text-4xl font-sora font-extrabold text-left mb-6 md:mb-8">Electronics</h2>

			<!-- Products Grid -->
			<div
				id="product-list"
				class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6"
			>
				{products.map((product: any) => (
					<ProductCard
						title={product.metadata.title ?? product.name}
						short={product.metadata.short}
						price={product.price}
						image={product.image}
						priceId={product.price_id}
					/>
				))}
			</div>
		</div>
	</section>
</Layout>

<script>
	document.addEventListener("DOMContentLoaded", () => {
		const searchInput = document.getElementById("search-input") as any;
		const productList = document.getElementById("product-list");

		if (!searchInput || !productList) return;

		searchInput.addEventListener("input", () => {
			const searchTerm = searchInput.value.toLowerCase();
			const products = productList.children;

			Array.from(products).forEach((product) => {
				const productElement = product as any;
				const titleElement = productElement.querySelector("[data-product-title]");

				if (!titleElement) return;

				const title = titleElement.textContent?.toLowerCase();
				productElement.style.display = title && title.includes(searchTerm) ? "flex" : "none";
			});
		});
	});
</script>
